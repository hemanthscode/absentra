{
  "name": "absentra-backend",
  "version": "1.0.0",
  "description": "Employee Leave Management System Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node src/seeds/seed.js",
    "seed:force": "node src/seeds/seed.js --force",
    "clear:db": "node src/seeds/clearDB.js",
    "clear:db:force": "node src/seeds/clearDB.js --force",
    "reset:db": "npm run clear:db && npm run seed",
    "reset:db:force": "npm run clear:db:force && npm run seed"
  },
  "keywords": [
    "leave-management",
    "mern",
    "express"
  ],
  "author": "Hemanth Venkata Chowdary Sayimpu",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "nodemailer": "^8.0.8"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
